<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <!-- Essential parameters -->
  <arg name="map_path" description="point cloud and lanelet2 map directory path"/>
  <arg name="vehicle_model" default="sample_vehicle" description="vehicle model name"/>
  <arg name="sensor_model" default="sample_sensor_kit" description="sensor model name"/>
  <arg name="data_path" default="$(env HOME)/autoware_data" description="packages data and artifacts directory path"/>

  <!-- Minimal preset -->
  <arg name="planning_module_preset" default="minimal" description="planning module preset"/>
  <arg name="control_module_preset" default="minimal" description="control module preset"/>

  <!-- Map -->
  <arg name="lanelet2_map_file" default="lanelet2_map.osm" description="lanelet2 map file name"/>
  <arg name="pointcloud_map_file" default="pointcloud_map.pcd" description="pointcloud map file name"/>
  
  <!-- System -->
  <arg name="launch_system_monitor" default="false" description="launch system monitor"/>
  <arg name="launch_dummy_diag_publisher" default="true" description="launch dummy diag publisher"/>
  
  <!-- Scenario simulation -->
  <arg name="initial_engage_state" default="true" description="/vehicle/engage state after starting Autoware"/>
  <arg name="scenario_simulation" default="false" description="use scenario simulation"/>
  
  <!-- Tools -->
  <arg name="rviz" default="false" description="launch rviz"/>
  <arg name="rviz_config" default="$(find-pkg-share autoware_launch)/rviz/autoware.rviz" description="rviz config path"/>
  
  <!-- Vcu emulation -->
  <arg name="vehicle_simulation" default="true" description="use vehicle simulation"/>
  
  <!-- Auto mode setting-->
  <arg name="enable_all_modules_auto_mode" default="false" description="enable all module's auto mode"/>
  
  <!-- Simulated time -->
  <arg name="use_sim_time" default="false"/>
  
  <!-- Localization-->
  <arg name="localization_sim_mode" default="none" description="none - no localization modules"/>

  <group scoped="false">
    <!-- Vehicle -->
    <let name="launch_vehicle_interface" value="false"/>

    <include file="$(find-pkg-share autoware_launch)/launch/autoware.launch.xml">
      <!-- Common -->
      <arg name="map_path" value="$(var map_path)"/>
      <arg name="vehicle_model" value="$(var vehicle_model)"/>
      <arg name="sensor_model" value="$(var sensor_model)"/>
      <arg name="data_path" value="$(var data_path)"/>
      
      <!-- launch module preset -->
      <arg name="planning_module_preset" value="$(var planning_module_preset)"/>
      <arg name="control_module_preset" value="$(var control_module_preset)"/>
      
      <!-- Modules to be launched - MINIMAL CONFIGURATION -->
      <arg name="launch_vehicle" value="true"/>
      <arg name="launch_system" value="false"/>  <!-- Disable system monitoring -->
      <arg name="launch_map" value="true"/>  <!-- Keep map for routing -->
      <arg name="launch_sensing" value="false"/>  <!-- No sensors -->
      <arg name="launch_localization" value="false"/>  <!-- No localization -->
      <arg name="launch_perception" value="false"/>  <!-- No perception -->
      <arg name="launch_planning" value="true"/>  <!-- Keep planning -->
      <arg name="launch_control" value="true"/>  <!-- Keep control -->
      <arg name="launch_api" value="true"/>  <!-- Keep API for control -->
      
      <!-- Vehicle -->
      <arg name="launch_vehicle_interface" value="$(var launch_vehicle_interface)"/>
      
      <!-- System -->
      <arg name="system_run_mode" value="planning_simulation"/>
      <arg name="launch_system_monitor" value="$(var launch_system_monitor)"/>
      <arg name="launch_dummy_diag_publisher" value="$(var launch_dummy_diag_publisher)"/>
      
      <!-- Map -->
      <arg name="lanelet2_map_file" value="$(var lanelet2_map_file)"/>
      <arg name="pointcloud_map_file" value="$(var pointcloud_map_file)"/>
      
      <!-- Tools -->
      <arg name="rviz" value="$(var rviz)"/>
      <arg name="rviz_config" value="$(var rviz_config)"/>
      
      <!-- Auto mode setting-->
      <arg name="enable_all_modules_auto_mode" value="$(var enable_all_modules_auto_mode)"/>
      <arg name="is_simulation" value="true"/>
    </include>
  </group>

  <!-- Minimal Simulator - dummy modules only -->
  <group>
    <include file="$(find-pkg-share autoware_launch)/launch/components/tier4_simulator_component.launch.xml">
      <arg name="launch_dummy_perception" value="true"/>
      <arg name="launch_dummy_vehicle" value="true"/>
      <arg name="localization_sim_mode" value="$(var localization_sim_mode)"/>
      <arg name="launch_dummy_doors" value="false"/>
      <arg name="perception/enable_detection_failure" value="false"/>
      <arg name="perception/enable_object_recognition" value="false"/>
      <arg name="initial_engage_state" value="$(var initial_engage_state)"/>
      <arg name="vehicle_model" value="$(var vehicle_model)"/>
    </include>
  </group>

</launch>
